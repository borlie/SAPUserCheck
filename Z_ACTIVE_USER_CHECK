*----------------------------------------------------------------------*
* CLASS lcl_alv_events DEFINITION
*----------------------------------------------------------------------*
CLASS lcl_alv_events DEFINITION.
  PUBLIC SECTION.
    METHODS:
      on_user_command FOR EVENT added_function OF cl_salv_events_table
        IMPORTING e_salv_function,
      on_link_click   FOR EVENT link_click OF cl_salv_events_table
        IMPORTING row column.
ENDCLASS.

*----------------------------------------------------------------------*
* CONSTANTS & GLOBAL DATA
*----------------------------------------------------------------------*
CONSTANTS:
  c_scope  TYPE string VALUE 'https://graph.microsoft.com/.default',
  c_tenant TYPE string VALUE '<paste the tenant id here>'.

DATA:
  gv_token   TYPE string,
  gt_results TYPE tt_user_result,
  go_alv     TYPE REF TO cl_salv_table.

DATA: go_events TYPE REF TO lcl_alv_events.

*----------------------------------------------------------------------*
* CLASS lcl_alv_events IMPLEMENTATION
*----------------------------------------------------------------------*
CLASS lcl_alv_events IMPLEMENTATION.
  METHOD on_user_command.
    FIELD-SYMBOLS: <fs_row> TYPE ty_user_result.
    DATA: ls_stable TYPE lvc_s_stbl.

    ls_stable-row = abap_true.
    ls_stable-col = abap_true.

    CASE e_salv_function.
      WHEN 'PROCESS'.
        PERFORM process_selected_users.

      WHEN 'SEL_ACT'.
        LOOP AT gt_results ASSIGNING <fs_row>.
          IF <fs_row>-admin_proposal <> 'No Action' AND <fs_row>-admin_proposal <> 'Action Completed'.
            <fs_row>-mark = 'X'.
          ELSE.
            <fs_row>-mark = ' '.
          ENDIF.
        ENDLOOP.
        go_alv->refresh( s_stable = ls_stable refresh_mode = if_salv_c_refresh=>full ).

      WHEN 'DSEL_ALL'.
        LOOP AT gt_results ASSIGNING <fs_row>.
          <fs_row>-mark = ' '.
        ENDLOOP.
        go_alv->refresh( s_stable = ls_stable refresh_mode = if_salv_c_refresh=>full ).

      WHEN 'SET_LOCK'.
        LOOP AT gt_results ASSIGNING <fs_row> WHERE mark = 'X'.
          <fs_row>-admin_proposal = 'Lock User'.
          <fs_row>-mark = ' '.
        ENDLOOP.
        go_alv->refresh( s_stable = ls_stable refresh_mode = if_salv_c_refresh=>full ).

      WHEN 'SET_TERM'.
        LOOP AT gt_results ASSIGNING <fs_row> WHERE mark = 'X'.
          <fs_row>-admin_proposal = 'Terminate User'.
          <fs_row>-mark = ' '.
        ENDLOOP.
        go_alv->refresh( s_stable = ls_stable refresh_mode = if_salv_c_refresh=>full ).

      WHEN 'SET_UPDT'.
        LOOP AT gt_results ASSIGNING <fs_row> WHERE mark = 'X'.
          <fs_row>-admin_proposal = 'Update Address Data'.
          <fs_row>-mark = ' '.
        ENDLOOP.
        go_alv->refresh( s_stable = ls_stable refresh_mode = if_salv_c_refresh=>full ).

      WHEN 'SET_NONE'.
        LOOP AT gt_results ASSIGNING <fs_row> WHERE mark = 'X'.
          <fs_row>-admin_proposal = 'No Action'.
          <fs_row>-mark = ' '.
        ENDLOOP.
        go_alv->refresh( s_stable = ls_stable refresh_mode = if_salv_c_refresh=>full ).

    ENDCASE.
  ENDMETHOD.

  METHOD on_link_click.
    FIELD-SYMBOLS: <fs_row> TYPE ty_user_result.
    DATA: ls_stable TYPE lvc_s_stbl.
    ls_stable-row = abap_true.
    ls_stable-col = abap_true.

    IF column = 'MARK'.
      READ TABLE gt_results ASSIGNING <fs_row> INDEX row.
      IF sy-subrc = 0.
        IF <fs_row>-mark = 'X'.
          <fs_row>-mark = ' '.
        ELSE.
          <fs_row>-mark = 'X'.
        ENDIF.
        go_alv->refresh( s_stable = ls_stable refresh_mode = if_salv_c_refresh=>full ).
      ENDIF.
    ENDIF.
  ENDMETHOD.
ENDCLASS.

